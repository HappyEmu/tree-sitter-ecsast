{
  "name": "tree-sitter-ecsast",
  "version": "0.0.1",
  "description": "Tree-sitter grammar for the ECSAST language",
  "main": "bindings/node",
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.ecsast",
      "file-types": ["ecs"],
      "injection-regex": "^ecsast$"
    }
  ],
  "devDependencies": {
    "tree-sitter-cli": "^0.23.0"
  }
}
